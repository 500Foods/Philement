{
  "server": {
    "url": "https://lithium.philement.com",
    "api_prefix": "/api",
    "websocket_url": "wss://lithium.philement.com/wss"
  },
  "auth": {
    "api_key": "EveryGoodBoyDeservesFudge",
    "default_database": "Lithium",
    "session_timeout_minutes": 30
