{
  "name": "lithium-pwa",
  "version": "1.0.0",
  "description": "Lithium Progressive Web App with Vanilla JavaScript",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "dev": "vite dev",
    "build": "vite build",
    "build:prod": "vite build --mode production && npm run minify-html",
    "preview": "vite preview",
    "minify-html": "html-minifier-terser --input-dir dist --output-dir dist --file-ext html --collapse-whitespace --remove-comments --minify-js --minify-css && terser dist/service-worker.js -o dist/service-worker.js --compress --mangle",
    "serve": "vite preview --port 3000",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ci": "cd tests && node test-runner.js",
    "lint": "eslint src/**/*.js tests/**/*.js",
    "lint:fix": "eslint src/**/*.js tests/**/*.js --fix",
    "format": "prettier --write src/**/*.js tests/**/*.js",
    "clean": "rm -rf dist coverage reports",
    "deploy": "npm run build:prod && rsync -avz dist/ user@server:/var/www/lithium/"
  },
  "dependencies": {
    "dompurify": "^3.3.2",
    "tabulator-tables": "^6.2.3",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@codemirror/lang-css": "^6.2.1",
    "@codemirror/lang-html": "^6.4.8",
    "@codemirror/lang-javascript": "^6.2.1",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-sql": "^6.5.5",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.23.0",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^10.0.0",
    "happy-dom": "^20.0.0",
    "html-minifier-terser": "^7.2.0",
    "prettier": "^3.2.5",
    "terser": "^5.44.1",
    "vite-plugin-html": "^3.2.2",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "pwa",
    "progressive-web-app",
    "vanilla-javascript",
    "spa",
    "offline-first"
  ],
  "author": "Philement",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/philement/lithium-pwa.git"
  },
  "bugs": {
    "url": "https://github.com/philement/lithium-pwa/issues"
  },
  "homepage": "https://philement.github.io/lithium-pwa/",
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead",
    "not op_mini all"
  ]
}
