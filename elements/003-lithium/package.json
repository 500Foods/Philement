{
  "name": "lithium-pwa",
  "version": "1.0.0",
  "description": "Lithium Progressive Web App with Vanilla JavaScript",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "dev": "vite dev",
    "validate:tabulator": "node scripts/validate-tabulator-config.js",
    "style:registry": "node scripts/generate-style-registry.js",
    "icon:registry": "node scripts/generate-icon-registry.js",
    "build": "npm run validate:tabulator && npm run lint:css && vite build && npm run style:registry && npm run icon:registry",
    "build:prod": "npm run validate:tabulator && npm run lint:css && vite build --mode production && npm run style:registry && npm run postbuild",
    "preview": "vite preview",
    "postbuild": "bash scripts/postbuild.sh",
    "serve": "vite preview --port 3000",
    "test": "vitest run && npm run test:quality",
    "test:watch": "vitest watch",
    "test:quality": "npx @opencodereview/cli@2.1.4 scan src/ 2>&1 || true",
    "test:coverage": "vitest run --coverage",
    "coverage:copy": "rm -rf public/coverage && cp -r coverage public/coverage 2>/dev/null || echo 'No coverage report found. Run npm run test:coverage first.'",
    "templates:copy": "node scripts/copy-templates.js",
    "test:ci": "cd tests && node test-runner.js",
    "lint": "eslint src/**/*.js tests/**/*.js --no-warn-ignored",
    "lint:css": "stylelint 'src/**/*.css' --allow-empty-input --max-warnings 0",
    "lint:css:fix": "stylelint 'src/**/*.css' --fix --allow-empty-input",
    "lint:fix": "eslint src/**/*.js tests/**/*.js --fix --no-warn-ignored && npm run lint:css:fix",
    "format": "prettier --write src/**/*.js tests/**/*.js",
    "clean": "rm -rf dist coverage reports",
    "predeploy": "test -n \"$LITHIUM_DEPLOY\" || { echo 'Error: $LITHIUM_DEPLOY is not set'; exit 1; }",
    "version:bump": "node scripts/bump-version.js",
    "build:deploy-only": "vite build --mode deploy",
    "deploy": "bash scripts/deploy-parallel.sh",
    "deploy:config": "test -f \"$LITHIUM_DEPLOY/config/lithium.json\" || cp -r \"$LITHIUM_ROOT/config\" \"$LITHIUM_DEPLOY/config\"; cp -f \"$LITHIUM_ROOT/config/icons-dev.txt\" \"$LITHIUM_DEPLOY/config/\" 2>/dev/null || true; cp -f \"$LITHIUM_ROOT/config/icons-usr.txt\" \"$LITHIUM_DEPLOY/config/\" 2>/dev/null || true",
    "deploy:postbuild": "bash scripts/postbuild.sh",
    "deploy:prune": "node scripts/prune-deploy-assets.js",
    "deploy:brotli": "node scripts/generate-brotli.js",
    "deploy:brotli:fast": "BROTLI_JOBS=12 scripts/generate-brotli.sh",
    "deploy:brotli:timed": "npm run deploy:brotli 2>&1 | tee /tmp/brotli-timing.log",
    "deploy:500courses": "bash scripts/deploy-500courses.sh"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/legacy-modes": "^6.5.3",
    "@eslint/js": "^10.0.1",
    "@floating-ui/dom": "^1.7.6",
    "@lezer/highlight": "^1.2.3",
    "country-flag-icons": "^1.6.15",
    "dompurify": "^3.3.2",
    "flatpickr": "^4.6.13",
    "luxon": "^3.7.2",
    "marked": "^17.0.4",
    "overlayscrollbars": "^2.15.1",
    "purgecss": "^8.0.0",
    "shepherd.js": "^15.2.2",
    "sql-formatter": "^15.3.0",
    "suneditor": "^3.0.0-beta.0",
    "tabulator-tables": "^6.2.3",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/comment": "^0.19.1",
    "@codemirror/lang-css": "^6.2.1",
    "@codemirror/lang-html": "^6.4.8",
    "@codemirror/lang-javascript": "^6.2.1",
    "@codemirror/lang-sql": "^6.5.5",
    "@codemirror/search": "^6.5.5",
    "@codemirror/state": "^6.4.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.23.0",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@vitest/coverage-v8": "^4.0.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.0.3",
    "happy-dom": "^20.0.0",
    "html-minifier-terser": "^7.2.0",
    "prettier": "^3.2.5",
    "stylelint": "^16.18.0",
    "stylelint-config-standard": "^37.0.0",
    "terser": "^5.44.1",
    "vite-plugin-html": "^3.2.2",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "pwa",
    "progressive-web-app",
    "vanilla-javascript",
    "spa",
    "offline-first"
  ],
  "author": "Philement",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/philement/lithium-pwa.git"
  },
  "bugs": {
    "url": "https://github.com/philement/lithium-pwa/issues"
  },
  "homepage": "https://philement.github.io/lithium-pwa/",
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead",
    "not op_mini all"
  ]
}
