{
    "Server": {
        "ServerName": "hydrogen-test-45-oidc-idp",
        "PayloadKey": "${env.PAYLOAD_KEY}"
    },
    "WebServer": {
        "EnableIPv4": true,
        "EnableIPv6": false,
        "Port": 5451
    },
    "API": {
        "Enabled": true,
        "Prefix": "/api",
        "JWTSecret": "${env.HYDROGEN_DEMO_JWT_KEY}"
    },
    "OIDC": {
        "Enabled": true,
        "Issuer": "http://localhost:5451",
        "ClientId": "test-idp-public",
        "RedirectUri": "http://127.0.0.1:5459/cb",
        "Database": "Acuranzo",
        "Keys": {
            "StoragePath": "tests/artifacts/oidc_idp_keys_45",
            "EncryptionEnabled": false,
            "RotationIntervalDays": 90
        },
        "Tokens": {
            "AccessTokenLifetime": 3600,
            "RefreshTokenLifetime": 86400,
            "IdTokenLifetime": 3600,
            "SigningAlg": "RS256"
        }
    },
    "Databases": {
        "Connections": [
            {
                "Name": "Acuranzo",
                "Engine": "sqlite",
                "Enabled": true,
                "Database": "tests/artifacts/database/sqlite/hydrodemo.sqlite",
                "StmtCache": 100,
                "Bootstrap": "SELECT query_id id, query_ref ref, query_status_a27 status, query_type_a28 type, query_dialect_a30 engine, query_queue_a58 queue, query_timeout timeout, name, code query FROM queries WHERE (query_status_a27 = 1) ORDER BY query_type_a28 desc;",
                "AutoMigration": true,
                "TestMigration": false,
                "Parameters": {
                    "LOGINRETRYWINDOW": 15,
                    "IPADDRESS": "10.10.10.10",
                    "LOGINID": "${env.HYDROGEN_DEMO_USER_NAME}"
                },
                "Schema": "",
                "Migrations": "PAYLOAD:acuranzo",
                "Queues": {
                    "Slow": {
                        "start": 2
                    }
                }
            }
        ]
    }
}
