{
    "Server": {
        "ServerName": "hydrogen-test-43-scripting-cockroachdb",
        "PayloadKey": "${env.PAYLOAD_KEY}"
    },
    "WebServer": {
        "EnableIPv4": true,
        "EnableIPv6": false,
        "Port": 15435
    },
    "Databases": {
        "Connections": [
            {
                "Enabled": true,
                "Name": "Acuranzo",
                "Engine": "${env.ACURANZO_DB_TYPE}",
                "Host": "${env.ACURANZO_DB_HOST}",
                "Port": "${env.ACURANZO_DB_PORT}",
                "Database": "${env.ACURANZO_DB_NAME}",
                "User": "${env.ACURANZO_DB_USER}",
                "Pass": "${env.ACURANZO_DB_PASS}",
                "StmtCache": 100,
                "Bootstrap":"SELECT query_id id, query_ref ref, query_status_a27 status, query_type_a28 type, query_dialect_a30 engine, query_queue_a58 queue, query_timeout timeout, name, code query FROM democrdb.queries WHERE (query_status_a27 = 1) ORDER BY query_type_a28 desc;",
                "AutoMigration": false,
                "TestMigration": false,
                "Parameters": {
                    "LOGINRETRYWINDOW": 15,
                    "IPADDRESS": "10.10.10.10",
                    "LOGINID": "${env.HYDROGEN_DEMO_USER_NAME}"
                },
                "Schema": "democrdb",
                "Migrations":"PAYLOAD:acuranzo",
                "Queues": {
                    "Slow": {
                        "start": 2
                    }
                }
            }
        ]
    },
    "Scripting": {
        "Enabled": true,
        "WorkerCount": 2,
        "Orchestrator": "Orchestrators.Orchestrator",
        "DefaultDatabase": "Acuranzo",
        "DefaultQueryTimeout": 30,
        "DefaultMaxRuntime": 3600,
        "InstructionHookInterval": 5000,
        "MemorySoftLimitKB": 32768,
        "MemoryHardLimitKB": 65536,
        "Sandbox": {
            "AllowOsTime": true,
            "AllowOsExecute": false,
            "AllowIo": false,
            "AllowDebug": false,
            "AllowLoadlib": false
        },
        "AllowDBModuleLoad": true
    }
}
