{
    "Server": {
        "ServerName": "hydrogen-test-58-db2",
        "PayloadKey": "${env.PAYLOAD_KEY}"
    },
    "WebServer": {
        "EnableIPv4": true,
        "EnableIPv6": false,
        "Port": 55809
    },
    "API": {
        "Enabled": true,
        "Prefix": "/api",
        "JWTSecret": "${env.HYDROGEN_DEMO_JWT_KEY}"
    },
    "Swagger": {
        "Enabled": true,
        "Prefix": "/swagger",
        "UIOptions": {
            "TryItEnabled": true,
            "AlwaysExpanded": true,
            "DisplayOperationId": true,
            "DefaultModelsExpandDepth": 1,
            "DefaultModelExpandDepth": 1,
            "ShowExtensions": false,
            "ShowCommonExtensions": true,
            "DocExpansion": "list",
            "SyntaxHighlightTheme": "agate"
        }
    },
    "Databases": {
        "Connections": [
            {
                "Enabled": true,
                "Name": "Acuranzo",
                "Engine": "${env.HYDROTST_DB_TYPE}",
                "Database": "${env.HYDROTST_DB_NAME}",
                "Host": "localhost",
                "Port": 55555,
                "StmtCache": 100,
                "User": "${env.HYDROTST_DB_USER}",
                "Pass": "${env.HYDROTST_DB_PASS}",
                "Bootstrap": "SELECT query_id \"id\", query_ref \"ref\", query_status_a27 \"status\", query_type_a28 \"type\", query_dialect_a30 \"engine\", query_queue_a58 \"queue\", query_timeout \"timeout\", name \"name\", code \"query\" FROM demo.queries WHERE (query_status_a27 = 1) ORDER BY query_type_a28 desc;",
                "AutoMigration": true,
                "TestMigration": false,
                "Migrations": "PAYLOAD:acuranzo",
                "Schema": "demo",
                "Parameters": {
                    "LOGINRETRYWINDOW": 15,
                    "IPADDRESS": "10.10.10.10"
                },
                "Queues": {
                    "Slow": {
                        "start": 2
                    }
                }
            }
        ]
    },
    "MailRelay": {
        "Enabled": true,
        "OutboundEnabled": true,
        "InboundEnabled": false,
        "ListenPort": 25,
        "Workers": 1,
        "DefaultFrom": "mailrelay-test@hydrogen.local",
        "DefaultReplyTo": "mailrelay-test@hydrogen.local",
        "Queue": {
            "MaxQueueSize": 1000,
            "MaxInMemory": 1000,
            "Persist": false,
            "RetryAttempts": 3,
            "RetryDelaySeconds": 300,
            "InitialDelaySeconds": 1,
            "MaxDelaySeconds": 3600,
            "DebounceSeconds": 5,
            "StaleTimeoutSeconds": 300
        },
        "Servers": [
            {
                "Host": "127.0.0.1",
                "Port": "55810",
                "UseTLS": false,
                "TLSMode": 0,
                "AuthMode": 0,
                "TimeoutSeconds": 15
            }
        ]
    }
}