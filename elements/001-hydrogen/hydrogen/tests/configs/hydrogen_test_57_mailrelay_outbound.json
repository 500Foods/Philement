{
    "Server": {
        "ServerName": "hydrogen-test-57"
    },
    "WebServer": {
        "EnableIPv4": false,
        "EnableIPv6": false
    },
    "MailRelay": {
        "Enabled": true,
        "OutboundEnabled": true,
        "InboundEnabled": false,
        "ListenPort": 25,
        "Workers": 1,
        "DefaultFrom": "mailrelay-test@hydrogen.local",
        "Queue": {
            "MaxQueueSize": 1000,
            "MaxInMemory": 1000,
            "Persist": false,
            "RetryAttempts": 3,
            "RetryDelaySeconds": 300,
            "InitialDelaySeconds": 10,
            "MaxDelaySeconds": 3600,
            "DebounceSeconds": 5
        },
        "Servers": [
            {
                "Host": "127.0.0.1",
                "Port": "5570",
                "UseTLS": false,
                "TLSMode": 0,
                "AuthMode": 0,
                "TimeoutSeconds": 15
            }
        ],
        "Test": {
            "SendRawOnLaunch": true,
            "TestFrom": "mailrelay-test@hydrogen.local",
            "TestTo": "sink@mailval.local",
            "TestSubject": "MailRelay Outbound Smoke Test (plaintext)",
            "TestBody": "This is the Hydrogen MailRelay Phase 2.6 plaintext smoke test body."
        }
    }
}
