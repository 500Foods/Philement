{
    "Server": {
        "ServerName": "hydrogen-test-45-db2",
        "PayloadKey": "${env.PAYLOAD_KEY}"
    },
    "WebServer": {
        "EnableIPv4": true,
        "EnableIPv6": false,
        "Port": 5453
    },
    "API": {
        "Enabled": true,
        "Prefix": "/api",
        "JWTSecret": "${env.HYDROGEN_DEMO_JWT_KEY}"
    },
    "OIDC": {
        "Enabled": true,
        "Issuer": "http://localhost:5453",
        "ClientId": "test-idp-public",
        "RedirectUri": "http://127.0.0.1:5459/cb",
        "Database": "Acuranzo",
        "Keys": {
            "StoragePath": "tests/artifacts/oidc_idp_keys_45_db2",
            "EncryptionEnabled": false,
            "RotationIntervalDays": 90
        },
        "Tokens": {
            "AccessTokenLifetime": 3600,
            "RefreshTokenLifetime": 86400,
            "IdTokenLifetime": 3600,
            "SigningAlg": "RS256"
        }
    },
    "Databases": {
        "Connections": [
            {
                "Enabled": true,
                "Name": "Acuranzo",
                "Engine": "${env.HYDROTST_DB_TYPE}",
                "Database": "${env.HYDROTST_DB_NAME}",
                "Host": "localhost",
                "Port": 55555,
                "StmtCache": 100,
                "User": "${env.HYDROTST_DB_USER}",
                "Pass": "${env.HYDROTST_DB_PASS}",
                "Bootstrap": "SELECT query_id \"id\", query_ref \"ref\", query_status_a27 \"status\", query_type_a28 \"type\", query_dialect_a30 \"engine\", query_queue_a58 \"queue\", query_timeout \"timeout\", name \"name\", code \"query\" FROM demo.queries WHERE (query_status_a27 = 1) ORDER BY query_type_a28 desc;",
                "AutoMigration": true,
                "TestMigration": false,
                "Migrations": "PAYLOAD:acuranzo",
                "Schema": "demo",
                "Parameters": {
                    "LOGINRETRYWINDOW": 15,
                    "IPADDRESS": "10.10.10.14",
                    "LOGINID": "${env.HYDROGEN_DEMO_USER_NAME}"
                },
                "Queues": {
                    "Slow": {
                        "start": 2
                    }
                }
            }
        ]
    }
}
